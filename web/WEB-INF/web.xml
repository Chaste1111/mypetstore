        <servlet-class>csu.web.mypetstore.web.servlet.SubmitOrderServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>SearchServlet</servlet-name>
        <servlet-class>csu.web.mypetstore.web.servlet.SearchServlet</servlet-class>
