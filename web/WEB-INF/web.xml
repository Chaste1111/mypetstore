        <servlet-class>csu.web.mypetstore.web.servlet.SignOnServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>RegisterServlet</servlet-name>
        <servlet-class>csu.web.mypetstore.web.servlet.RegisterServlet</servlet-class>
